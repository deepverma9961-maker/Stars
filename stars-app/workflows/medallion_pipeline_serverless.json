{
  "name": "stars_medallion_pipeline",
  "description": "StarPulse Medicare Stars - Bronze \u00e2\u2020\u2019 Silver \u00e2\u2020\u2019 Gold medallion pipeline",
  "tasks": [
    {
      "task_key": "bronze_enrollment",
      "description": "Generate bronze_enrollment_raw (100k synthetic members)",
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/bronze/01_bronze_enrollment",
        "base_parameters": {
          "seed": "42",
          "catalog": "aiagneticdemo",
          "n_members": "100000"
        }
      },
      "timeout_seconds": 1800,
      "max_retries": 1,
      "min_retry_interval_millis": 60000,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "bronze_claims",
      "description": "Generate bronze_claims_raw (1.8M claims)",
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/bronze/02_bronze_claims",
        "base_parameters": {
          "seed": "42",
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 3600,
      "max_retries": 1,
      "min_retry_interval_millis": 60000,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "bronze_pharmacy",
      "description": "Generate bronze_pharmacy_raw (1.1M Rx fills)",
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/bronze/03_bronze_pharmacy",
        "base_parameters": {
          "seed": "42",
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 2400,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "bronze_cahps",
      "description": "Generate bronze_cahps_survey_raw (10k survey responses)",
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/bronze/04_bronze_cahps",
        "base_parameters": {
          "seed": "42",
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 900,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "bronze_call_center",
      "description": "Generate bronze_call_center_raw (375k calls)",
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/bronze/05_bronze_call_center",
        "base_parameters": {
          "seed": "42",
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 1800,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "silver_member_plan",
      "description": "Build silver_member (100k) + silver_plan (28) + silver_provider (12k)",
      "depends_on": [
        {
          "task_key": "bronze_enrollment"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/silver/06_silver_member_plan",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 2400,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "silver_measure_cahps",
      "description": "Build silver_measure (45) + silver_cahps_response (12k)",
      "depends_on": [
        {
          "task_key": "bronze_cahps"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/silver/07_silver_measure_cahps",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 1200,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "silver_clinical_events",
      "description": "Build silver_claim + silver_pharmacy_fill + silver_outreach_event + silver_call_event",
      "depends_on": [
        {
          "task_key": "bronze_claims"
        },
        {
          "task_key": "bronze_pharmacy"
        },
        {
          "task_key": "bronze_call_center"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/silver/08_silver_clinical_events",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 5400,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "gold_star_ratings",
      "description": "Build gold_star_rating_summary (28 rows)",
      "depends_on": [
        {
          "task_key": "silver_member_plan"
        },
        {
          "task_key": "silver_measure_cahps"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/gold/09_gold_star_ratings",
        "base_parameters": {
          "catalog": "aiagneticdemo",
          "measurement_year": "2025"
        }
      },
      "timeout_seconds": 900,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "gold_measure_scorecard",
      "description": "Build gold_measure_scorecard (1,260 rows = 28 plans \u00c3\u2014 45 measures)",
      "depends_on": [
        {
          "task_key": "silver_measure_cahps"
        },
        {
          "task_key": "silver_clinical_events"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/gold/10_gold_measure_scorecard",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 1800,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "gold_member_gaps",
      "description": "Build gold_member_gap (~260k rows)",
      "depends_on": [
        {
          "task_key": "gold_measure_scorecard"
        },
        {
          "task_key": "silver_member_plan"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/gold/11_gold_member_gaps",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 3600,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "gold_cahps_teamview",
      "description": "Build gold_cahps_overview (28 rows) + gold_team_view (6 rows)",
      "depends_on": [
        {
          "task_key": "silver_measure_cahps"
        },
        {
          "task_key": "silver_member_plan"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/gold/12_gold_cahps_teamview",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 1200,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "gold_campaigns_alerts",
      "description": "Build gold_campaign_performance + gold_alert_priority + gold_intervention_hub",
      "depends_on": [
        {
          "task_key": "gold_measure_scorecard"
        },
        {
          "task_key": "gold_member_gaps"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/gold/13_gold_campaigns_alerts",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 1800,
      "max_retries": 1,
      "environment_key": "medallion_env"
    },
    {
      "task_key": "gold_hos",
      "description": "Build gold_hos_measures (5) + gold_hos_scorecard (70) + gold_hos_members (~14k) + gold_hos_provider_scorecard (~1k)",
      "depends_on": [
        {
          "task_key": "silver_member_plan"
        },
        {
          "task_key": "silver_clinical_events"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/stars-app/notebooks/gold/14_gold_hos",
        "base_parameters": {
          "catalog": "aiagneticdemo"
        }
      },
      "timeout_seconds": 2400,
      "max_retries": 1,
      "environment_key": "medallion_env"
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "America/New_York",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": [
      "deepverma9934@gmail.com"
    ],
    "on_success": [
      "deepverma9934@gmail.com"
    ]
  },
  "format": "MULTI_TASK",
  "environments": [
    {
      "environment_key": "medallion_env",
      "spec": {
        "client": "1",
        "libraries": [
          {
            "pypi": {
              "package": "faker==24.0.0"
            }
          },
          {
            "pypi": {
              "package": "numpy==1.26.4"
            }
          }
        ]
      }
    }
  ]
}